# Obsidian Vault
VAULT_PATH=/Users/yourname/Documents/Obsidian Vault
DAILY_FOLDER=Daily

# Google OAuth
# Download credentials.json from Google Cloud Console:
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Notion
# Create an integration at https://www.notion.so/my-integrations
# Then share any pages/databases with the integration — they're picked up automatically
NOTION_API_KEY=secret_xxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-opus-4-5
